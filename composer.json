{
    "name": "tippiti/api-client",
    "description": "Official PHP client for the Tippiti API – the transcription and dictation platform for physicians, attorneys, forensic examiners and professional typing services.",
    "type": "library",
    "keywords": [
        "tippiti",
        "transcription",
        "dictation",
        "medical-transcription",
        "legal-transcription",
        "openapi",
        "api-client",
        "php"
    ],
    "homepage": "https://tippiti.io",
    "license": "MIT",
    "authors": [
        {
            "name": "Tippiti",
            "email": "support@tippiti.io",
            "homepage": "https://tippiti.io"
        }
    ],
    "support": {
        "docs": "https://apidocs.tippiti.io",
        "issues": "https://github.com/tippiti/tippiti-php/issues",
        "source": "https://github.com/tippiti/tippiti-php"
    },
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "guzzlehttp/guzzle": "^7.3",
        "guzzlehttp/psr7": "^1.7 || ^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5 || ^10.0"
    },
    "autoload": {
        "psr-4": {
            "Tippiti\\Api\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tippiti\\Api\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "generate": "./scripts/generate.sh"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
